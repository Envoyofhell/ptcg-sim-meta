{
  "name": "ptcg-sim",
  "version": "1.5.1",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "pnpm -C server start",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "predeploy": "pnpm -C client build",
    "deploy": "cd server && node server.js && gh-pages -d ../client/dist"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "nodemon": "^3.1.9",
    "gh-pages": "^5.0.0"
  }
}