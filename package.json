{
  "name": "ptcg-sim-meta",
  "version": "1.5.1",
  "description": "Pokémon TCG Tabletop Simulator with Meta features",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@8.15.5",
  "engines": {
    "node": ">=18.17.1 <19.0.0",
    "pnpm": ">=8.0.0"
  },
  "workspaces": [
    "client",
    "workers",
    "server"
  ],
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "husky install",

    "dev": "concurrently \"pnpm:dev:client\" \"pnpm:dev:worker\" \"pnpm:dev:server\"",
    "dev:client": "pnpm --filter client dev",
    "dev:worker": "pnpm --filter workers dev",
    "dev:server": "pnpm --filter server dev",


    "build": "turbo run build",
    "build:client": "vite build",
    "build:worker": "wrangler deploy workers/index.js",
    "build:server": "tsc -p server/tsconfig.json",


    "lint": "turbo run lint",
    "lint:client": "eslint client --ext .js,.jsx,.ts,.tsx",
    "lint:worker": "eslint workers --ext .js,.ts",
    "lint:server": "eslint server --ext .js,.ts",
    
    "lint:fix": "turbo run lint:fix",
    "lint:client:fix": "eslint client --ext .js,.jsx,.ts,.tsx --fix",
    "lint:worker:fix": "eslint workers --ext .js,.ts --fix",
    "lint:server:fix": "eslint server --ext .js,.ts --fix",

    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",

 
    "typecheck": "turbo run typecheck",
    "typecheck:client": "tsc --noEmit -p client/tsconfig.json",
    "typecheck:worker": "tsc --noEmit -p workers/tsconfig.json",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",


    "test": "turbo run test",
    "test:client": "vitest run --config client/vitest.config.ts",
    "test:worker": "vitest run --config workers/vitest.config.ts",
    "test:server": "vitest run --config server/vitest.config.ts",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",

    "deploy": "turbo run deploy",
    "deploy:preview": "pnpm deploy:pages:preview && pnpm deploy:worker:preview",
    "deploy:production": "pnpm deploy:pages:production && pnpm deploy:worker:production",
    
    "deploy:pages:preview": "wrangler pages deploy ./client --branch=preview",
    "deploy:pages:production": "wrangler pages deploy ./client --branch=main",
    "deploy:worker:preview": "wrangler deploy workers/index.js --env preview",
    "deploy:worker:production": "wrangler deploy workers/index.js --env production",

    "db:local": "wrangler d1 execute ptcg-sim-meta-db-test --local --file=migrations/0000_initial.sql",
    "db:migrations": "wrangler d1 execute ptcg-sim-meta-db-test --file=migrations/0000_initial.sql",
    "db:prod-migrations": "wrangler d1 execute ptcg-sim-meta-db --env production --file=migrations/0000_initial.sql",

    "clean": "turbo run clean",
    "clean:client": "rimraf client/dist client/.turbo",
    "clean:worker": "rimraf workers/dist workers/.turbo",
    "clean:server": "rimraf server/dist server/.turbo",
    "clean:all": "rimraf node_modules .turbo dist",

    "start": "node server/dist/server.js",
    "prepare:husky": "husky install"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20240314.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "itty-router": "^4.0.23",
    "socket.io": "^4.7.4",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.6",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^18.6.1",
    "@commitlint/config-conventional": "^18.6.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^18.19.18",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-unused-imports": "^3.1.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "nodemon": "^3.0.3",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "turbo": "^1.13.0",
    "typescript": "^5.4.3",
    "vite": "^5.2.6",
    "vitest": "^1.4.0",
    "wrangler": "^4.4.0"
  },
  "lint-staged": {
    "**/*.{js,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Envoyofhell/ptcg-sim-meta.git"
  },
  "keywords": [
    "ptcg",
    "pokemon",
    "trading-card-game",
    "simulator",
    "cloudflare-workers"
  ],
  "author": "Envoyofhell",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Envoyofhell/ptcg-sim-meta/issues"
  },
  "homepage": "https://meta-ptcg.org"
}